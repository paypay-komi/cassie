{
  "version": "0.2.0",
  "configurations": [
{
    "name": "Launch sharder.js",
    "request": "launch",
    "program": "${workspaceFolder}/sharder.js",
    "skipFiles": [
        "<node_internals>/**"
    ],
    "type": "node"
}

    {
      "name": "Attach to Bot (PM2)",
      "type": "node",
      "request": "attach",
      "address": "localhost",
      "port": 9229,
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
