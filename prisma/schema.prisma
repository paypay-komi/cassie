// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model UserGlobalCommandStats {
    id          String   @id @default(cuid())
    // @userid
    userId      String
    commandName String
    count       Int      @default(0)
    lastUsed    DateTime @default(now())

    @@unique([userId, commandName])
    @@index([userId])
}

// ------------------------------------------------------
// Global Guild Settings Object
// ------------------------------------------------------
model GuildSettingsObject {
    id   String @id @default("guild_settings")
    data Json
}

// ------------------------------------------------------
// Global User Data Object
// ------------------------------------------------------
model UserDataObject {
    id   String @id @default("user_data")
    data Json
}

model todolist {
    id        String   @id @default(cuid())
    // @userid
    userId    String
    content   String
    createdAt DateTime @default(now())
    completed Boolean  @default(false)

    @@index([userId])
}

model reminder {
    id              String   @id @default(cuid())
    // @userid
    userId          String
    content         String
    remindAt        DateTime
    createdAt       DateTime @default(now())
    repeatingSecs   Int? // if set, this is the interval for repeating reminders
    remindInChannel Boolean  @default(false) // if true, reminder will be sent in the channel instead of DM
    channelId       String? // if remindInChannel is true, this is the ID of the channel to send the reminder in

    @@index([userId])
}

// ------------------------------------------------------
// Guild-Level Settings
// ------------------------------------------------------
model GuildSettings {
    guildId String @id
    prefix  String @default("c.")

    channels             ChannelSettings[]
    userSettings         GuildUserSettings[]
    disabledCommands     GuildDisabledCommand[]
    channelCommandAccess GuildChannelCommandAccess[]
    roleCommandAccess    GuildRoleCommandAccess[]
    userCommandAccess    GuildUserCommandAccess[]
}

model UserPrefix {
    // @userid
    userId String @id
    prefix String
}

model GuildTag {
    id        String   @id @default(cuid())
    guildId   String
    name      String
    content   String
    // @userid
    creatorId String
    uses      Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([guildId, name])
    @@index([guildId])
}

model ChatMessage {
    id        String   @id @default(cuid())
    // @userid
    userId    String
    guildId   String?
    channelId String?
    role      String
    content   String
    createdAt DateTime @default(now())

    @@index([userId, createdAt])
}

model GlobalAfkUser {
    // @userid
    userId String   @id
    reason String?
    since  DateTime @default(now())

    // Optional enhancements
    autoReply    Boolean @default(true)
    ignoreBots   Boolean @default(true)
    notifyOnPing Boolean @default(true)

    mentionCount Int @default(0)

    mentions GlobalAfkMention[]

    updatedAt DateTime @updatedAt
}

model userTimezone {
    // @userid
    userId         String   @id
    minsOffset     Int      @default(0)
    timeZoneString String?  @default("NONE")
    timeFormat     String?  @default("12H")
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
}

model GlobalAfkMention {
    id          String   @id @default(cuid())
    // @userid
    userId      String
    guildId     String
    channelId   String
    messageId   String
    // @userid
    mentionedBy String
    createdAt   DateTime @default(now())

    afkUser GlobalAfkUser @relation(fields: [userId], references: [userId], onDelete: Cascade)

    @@index([userId])
}

// ------------------------------------------------------
// Channel-Level Settings (per guild)
// ------------------------------------------------------
model ChannelSettings {
    id        Int    @id @default(autoincrement())
    channelId String

    guild   GuildSettings @relation(fields: [guildId], references: [guildId])
    guildId String
}

// ------------------------------------------------------
// Per-User Settings (per guild)
// ------------------------------------------------------
model GuildUserSettings {
    id      Int    @id @default(autoincrement())
    guildId String
    // @userid
    userId  String

    statTracking Boolean @default(true)

    guild GuildSettings @relation(fields: [guildId], references: [guildId])

    @@unique([guildId, userId])
    @@index([guildId])
    @@index([userId])
}

// ------------------------------------------------------
// Per-User Per-Command Stats (per guild or "dm")
// ------------------------------------------------------
model UserCommandStats {
    id          String   @id @default(cuid())
    // @userid
    userId      String
    guildId     String // use "dm" for direct messages
    commandName String
    count       Int      @default(0)
    lastUsed    DateTime @default(now())

    @@unique([userId, guildId, commandName])
    @@index([guildId])
    @@index([userId])
}

// ------------------------------------------------------
// Global Stats Container (ONE ROW ONLY)
// ------------------------------------------------------
model GlobalStats {
    id       String               @id @default("global")
    commands GlobalCommandStats[]
}

// ------------------------------------------------------
// Global Command Stats (children of GlobalStats)
// ------------------------------------------------------
model GlobalCommandStats {
    id          String   @id @default(cuid())
    commandName String
    count       Int      @default(0)
    lastUsed    DateTime @default(now())

    globalStats   GlobalStats @relation(fields: [globalStatsId], references: [id])
    globalStatsId String

    @@unique([globalStatsId, commandName])
}

model Idea {
    id       String @id @default(cuid())
    // @userid
    authorId String
    content  String
    status   String @default("pending") // "pending" | "approved" | "rejected"

    // moderation
    // @userid
    rejectedBy   String?
    rejectedAt   DateTime?
    rejectReason String?
    // @userid
    approvedBy   String?
    approvedAt   DateTime?

    // ai analysis
    aiResult       String? // "approved" | "pending" | "rejected"
    aiReason       String?
    aiThoughts     String?
    aiConfidence   Float?
    aiCategory     String? // "moderation" | "fun" | "economy" | "utility" | "music" | "info" | "other"
    aiImprovedIdea String?
    aiDuplicateOf  String?

    createdAt  DateTime   @default(now())
    vote_score Int        @default(0)
    votes      IdeaVote[]
}

model UserVoteStats {
    // @userid
    userId            String    @id
    lastVote          DateTime?
    totalVotes        Int       @default(0)
    voteStreak        Int       @default(0)
    bestStreak        Int       @default(0)
    lastClaimedReward DateTime?
    voteDmOptOut      Boolean   @default(false)
    updatedAt         DateTime  @updatedAt
}

model IdeaVote {
    id        String   @id @default(cuid())
    ideaId    String
    // @userid
    userId    String
    value     Int // 1 = upvote, -1 = downvote
    createdAt DateTime @default(now())
    idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

    @@unique([ideaId, userId])
    @@index([ideaId])
    @@index([userId])
}

model DblVote {
    // @userid
    userId            String    @id
    lastVote          DateTime?
    totalVotes        Int       @default(0)
    voteStreak        Int       @default(0)
    bestStreak        Int       @default(0)
    lastClaimedReward DateTime?
    updatedAt         DateTime  @updatedAt
}

model CourtCase {
    id String @id @default(cuid())

    guildId      String
    // @userid
    defendantId  String
    // @userid
    prosecutorId String

    channelId String
    messageId String? @unique
    threadId  String?

    reason String

    status CourtStatus @default(VOTING)

    voteDeadline DateTime?

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    closedAt  DateTime?

    votes CourtVote[]
}

model CourtVote {
    id String @id @default(cuid())

    caseId  String
    // @userid
    voterId String

    /// 1 = guilty, -1 = not guilty
    value Int

    votedAt   DateTime @default(now())
    updatedAt DateTime @updatedAt

    courtCase CourtCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

    @@unique([caseId, voterId])
    @@index([voterId])
}

// ------------------------------------------------------
// Command Access Control (replaces old JSON blobs)
// ------------------------------------------------------

// Guild-wide disabled command (no one can use it without an allow override)
model GuildDisabledCommand {
    id        String @id @default(cuid())
    guildId   String
    commandId String

    guild GuildSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

    @@unique([guildId, commandId])
    @@index([guildId])
}

// Channel-level command access (allow/deny override)
model GuildChannelCommandAccess {
    id        String  @id @default(cuid())
    guildId   String
    channelId String
    commandId String
    allowed   Boolean @default(false) // true = allow override, false = deny

    guild GuildSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

    @@unique([channelId, commandId])
    @@index([guildId])
    @@index([channelId])
}

// Per-role command access (allow = bypass guild/channel disable, deny = block regardless)
model GuildRoleCommandAccess {
    id        String  @id @default(cuid())
    guildId   String
    roleId    String
    commandId String
    allowed   Boolean // true = allowed (bypasses guild/channel disable), false = denied

    guild GuildSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

    @@unique([guildId, roleId, commandId])
    @@index([guildId])
    @@index([roleId])
}

// Per-user command access (allow = bypass everything, deny = block regardless)
model GuildUserCommandAccess {
    id        String  @id @default(cuid())
    guildId   String
    // @userid
    userId    String
    commandId String
    allowed   Boolean // true = allowed (bypasses guild/channel/role disable), false = denied

    guild GuildSettings @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

    @@unique([guildId, userId, commandId])
    @@index([guildId])
    @@index([userId])
}

enum CourtStatus {
    VOTING
    GUILTY
    NOT_GUILTY
    DISMISSED
}

model EchoChannel {
    id             String @id @default(cuid())
    guildId        String
    channelId      String @unique
    webhookId      String
    webhookToken   String
    echoChance     Float? @default(85)
    deleteDelayMin Int?   @default(10000)
    deleteDelayMax Int?   @default(300000)
    echoDelayMin   Int?   @default(0)
    echoDelayMax   Int?   @default(86400000)

    createdAt DateTime @default(now())

    messages EchoMessage[]

    @@index([guildId])
}

model EchoMessage {
    id                String    @id @default(cuid())
    guildId           String
    channelId         String
    // @userid
    authorId          String
    content           String
    deliverAt         DateTime
    deliveredAt       DateTime?
    createdAt         DateTime  @default(now())
    originalMessageId String?
    attachments       Json?
    poll              Json?
    embeds            Json?

    channel EchoChannel @relation(fields: [channelId], references: [channelId], onDelete: Cascade)

    @@index([deliverAt])
    @@index([channelId, deliverAt])
}

model TimeCapsule {
    id        String    @id @default(cuid())
    // @userid
    userId    String
    content   String
    sendAt    DateTime
    sentAt    DateTime?
    createdAt DateTime  @default(now())

    @@index([sendAt])
    @@index([userId, sendAt])
}

model Session {
    id  String @id @default(cuid())
    sid String @unique

    data      String
    expiresAt DateTime

    createdAt DateTime @default(now())
}

model GuildAnnouncement {
    guildId      String    @id
    channelId    String? // set = subscribed, null = not yet set or unsubscribed
    webhookId    String? // webhook for sending broadcast announcements
    webhookToken String? // webhook token
    optedOut     Boolean   @default(false) // true = user explicitly unsubscribed, stop nagging
    lastNagged   DateTime? // when we last nagged this guild, null = never nagged
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
}

model InviteClick {
    id        Int       @id @default(autoincrement())
    state     String?   @unique
    ref       String    @default("unknown")
    ip        String?
    userAgent String?
    guildId   String?
    matchedAt DateTime?
    createdAt DateTime  @default(now())

    @@index([ref])
    @@index([guildId])
    @@index([createdAt])
    @@index([state])
}

model ReactionGif {
    id        String   @id @default(uuid())
    hash      String   @unique
    actions   String[]
    fileType  String
    mediaHash BigInt?
    createdAt DateTime @default(now())

    @@index([hash, actions])
    @@index([mediaHash])
}

model SubmittedReactonGif {
    id          String    @id @default(uuid())
    actions     String[]
    hash        String    @unique
    fileType    String
    mediaHash   BigInt?
    createdAt   DateTime  @default(now())
    approvedAt  DateTime?
    pending     Boolean   @default(true)
    // @userid
    submittedBy String
    // @userid
    approvedBy  String?

    @@index([hash, actions])
    @@index([mediaHash])
}
